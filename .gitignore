# ============================================================
# Bone-Met-Project: track ONLY the two analysis projects' CODE.
# Large data/models stay local — GitHub rejects files > 100 MB.
# ============================================================

# ignore everything at the repo root by default...
/*
# ...except these:
!/.gitignore
!/README.md
!/prostate-cancer/
!/kidney-cancer/
!/analysis/
!/figures/
!/environment.yml
!/install.R
!/renv.lock

# inside the tracked projects, still exclude big data & run artifacts
**/Data/
**/Cleaned_Data/
**/env_packs/
**/envs/
**/celloracle_objects/
**/*_integration_model/
**/annotation_model/
**/*.h5ad
**/*.h5
**/*.loom
**/*.mtx
**/*.count.csv
**/markers_scvi.csv
**/*.log
**/*.err
**/*.out
**/*.tmp
**/.*.h5ad.*

# python / jupyter junk
**/__pycache__/
**/.ipynb_checkpoints/
**/*.pyc
**/.DS_Store

# large generated analysis outputs (decoupler / SCENIC / cellrank) — regenerable, kept local
**/*.parquet
**/additional_analysis/outputs/

# large CellChat objects (regenerable)
**/outputs/tables/*.rds
**/rcc_ck_copykat_raw*.txt

# analysis process/meta docs — kept local, NOT published to the paper repo
/analysis/DATA_MANIFEST.md
/analysis/rcc_reinterpretation/CLAUDE.md
/analysis/rcc_reinterpretation/CHANGELOG.md
/analysis/rcc_reinterpretation/CORRECTION_prostate_object.md
/analysis/rcc_reinterpretation/DISCUSSION_VALIDATION.md
/analysis/rcc_reinterpretation/PRIOR_ART_AND_CLAIMS.md
**/outputs/tables/*status.md
**/PHASE2_STATUS
**/outputs/tables/_superseded_wrongobj/

# CellChat/CopyKAT input-staging intermediates (regenerable from scripts)
**/outputs/tables/cellchat_input/
**/outputs/tables/copykat_input/

# ---- publication hygiene (added 2026-07-22) ----
# CNV validation intermediates: only the summary table and the figure are needed
analysis/**/outputs/cnv/copykat/
analysis/**/outputs/cnv/infercnv/*
!analysis/**/outputs/cnv/infercnv/cnv_score_per_cell.csv
!analysis/**/outputs/cnv/infercnv/cnv_summary_by_compartment.csv
analysis/**/outputs/tables/copykat_input/
analysis/**/outputs/tables/cellchat_input/
analysis/**/outputs/tables/*.rds
analysis/**/outputs/tables/*.parquet

# scheduler + run artefacts
**/logs/
**/*.sbatch
**/*.out
**/*.err
**/__pycache__/
**/.ipynb_checkpoints/

# internal working notes and analysis records: kept locally, not published
analysis/**/CLAUDE.md
analysis/**/CHANGELOG.md
analysis/**/CLAIM_LEDGER.md
analysis/**/PHASE*
analysis/**/*_ADDENDUM*.md
analysis/**/DATA_UPDATE_*.md
analysis/DATA_MANIFEST.md
kidney-cancer/analysis/
kidney-cancer/deprecated/
analysis/**/22_copykat*
prostate-cancer/verify_transfer.sh
